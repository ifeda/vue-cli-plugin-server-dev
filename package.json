{
  "name": "vue-cli-plugin-server-dev",
  "version": "2.0.0",
  "description": "Easily start Your development server program and proxy it by Vue App Dev Server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "server",
    "vue",
    "cli",
    "vue-cli",
    "vue-cli-plugin",
    "webpack",
    "dev",
    "proxy"
  ],
  "dependencies": {
    "@vue/cli-shared-utils": "^5.0.8",
    "chokidar": "^3.6.0",
    "execa": "^5.1.1",
    "lodash": "^4.17.21",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/ifeda/vue-cli-plugin-server-dev.git"
  },
